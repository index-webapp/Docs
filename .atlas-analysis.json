  "keyFeatures": [
    "Multi-chain blockchain explorer with token, contract, wallet, and liquidity lookup",
    "AI-powered smart contract audit with risk scoring and honeypot detection",
    "Wallet intelligence with PnL tracking, portfolio analysis, and whale monitoring",
    "Smart liquidity routing across Raydium, Orca, Jupiter, and Pump.fun",
    "Real-time market analytics with charts, trending tokens, and alerts",
    "SURCHI governance token on Solana SPL with staking and premium feature access",
    "REST API and SDK for programmatic access to analytics data",
    "Webhook notifications for on-chain events and alerts"
  ],
